rules_version = '2';
// Updated with chat functionality rules
service cloud.firestore {
  match /databases/{database}/documents {

    match /ideas/{ideaId} {
      allow read: if true;

      // Anyone logged in can create
      allow create: if request.auth != null;

      // Allow updates ONLY if:
      // Either the author edits content
      // OR a user is updating only likeCount/commentCount
      allow update: if request.auth != null &&
        (
          request.auth.uid == resource.data.authorId || 
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['likeCount', 'commentCount'])
          )
        );

      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;

      // Likes
      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Comments
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }
    }
    
    // Users collection - allow users to read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Chats subcollection - each user can only access their own chats
      match /chats/{chatId} {
        // User can only read/write their own chats
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        // Messages subcollection - each user can only access messages in their own chats
        match /messages/{messageId} {
          // User can only read/write messages in their own chats
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Notifications subcollection - user-specific notifications
      // Types: welcome, completion, user-specific messages
      // Each user can only manage their own notifications
      match /notifications/{notificationId} {
        // Users can read their own notifications
        allow read: if request.auth != null && request.auth.uid == userId;
        
        // Users can update their own notifications (to change status: deleted/read/unread)
        allow update: if request.auth != null && request.auth.uid == userId;
        
        // Admin can create notifications for users (via migration or cloud functions)
        allow create: if request.auth != null && 
                     request.auth.email == 'arerajendhar33@gmail.com';
        
        // Users can delete their own notifications
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // pendingVerifications collection - used during email verification signup flow
    // Users are unauthenticated at this stage, allow access with basic field validation
    match /pendingVerifications/{docId} {
      // Anyone can create a pending verification (unauthenticated signup flow)
      allow create: if request.resource.data.keys().hasAll(['email', 'codeHash', 'expiryTime', 'createdAt']);
      // Anyone can read (needed to verify the code before user account exists)
      allow read: if true;
      // Allow update to increment attempts or resend count
      allow update: if true;
      // Allow delete after successful verification or too many attempts
      allow delete: if true;
    }

    // pendingPasswordResets collection - used during password reset flow
    // Users are unauthenticated at this stage (forgot password), allow access with field validation
    match /pendingPasswordResets/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'codeHash', 'expiryTime', 'createdAt']);
      allow read: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Tutorial ratings — real-time ratings and feedback
    match /tutorialRatings/{tutorialId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /userRatings/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /feedbacks/{feedbackId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }
    }

    // Discussions collection
    match /discussions/{discussionId} {
      allow read: if true;
      
      // Anyone logged in can create a discussion
      allow create: if request.auth != null;
      
      // Allow updates only by the author
      allow update: if request.auth != null && 
                   request.auth.uid == resource.data.authorId;
      
      // Allow deletion only by the author
      allow delete: if request.auth != null && 
                   request.auth.uid == resource.data.authorId;
      
      // Discussion replies/subcollections
      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && 
                               request.auth.uid == resource.data.authorId;
      }
    }
    
    // Tutorial stats — real-time view counts per tutorial
    match /tutorialStats/{tutorialId} {
      allow read: if true;
      allow write: if true;
    }

    // Tutorial feedbacks — real-time feedback per tutorial (same pattern as ideas/comments)
    match /tutorialFeedbacks/{tutorialId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /items/{feedbackId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }
    }

    // Platform experiences - testimonials submitted by students/teachers
    match /platformExperiences/{experienceId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Blogs collection - published blog posts
    match /blogs/{blogId} {
      // Anyone can read published blogs
      allow read: if resource.data.status == 'published' || request.auth != null;
      
      // Authenticated users can create blog posts
      allow create: if request.auth != null &&
                   request.resource.data.keys().hasAll(['title', 'excerpt', 'content', 'category']);
      
      // Only author can update their own blog
      allow update: if request.auth != null && 
                   request.auth.uid == resource.data.authorId;
      
      // Only author can delete their own blog
      allow delete: if request.auth != null && 
                   request.auth.uid == resource.data.authorId;
    }

    // Pending blogs collection - awaiting admin approval
    match /pending_blogs/{blogId} {
      // Authenticated users can read their own pending blogs
      allow read: if request.auth != null && 
                 request.auth.uid == resource.data.authorId;
      
      // Authenticated users can create pending blog submissions
      allow create: if request.auth != null &&
                   request.resource.data.authorId == request.auth.uid &&
                   request.resource.data.keys().hasAll(['title', 'excerpt', 'content', 'authorId', 'authorEmail']);
      
      // Only author can update their pending blog before approval
      allow update: if request.auth != null && 
                   request.auth.uid == resource.data.authorId &&
                   resource.data.status == 'pending';
      
      // Only author can delete their pending blog
      allow delete: if request.auth != null && 
                   request.auth.uid == resource.data.authorId;
    }

    // GLOBAL NOTIFICATIONS COLLECTION
    // These are for all users: maintenance, announcements, system-wide messages
    match /notifications/{notificationId} {
      // Authenticated users can read active global notifications
      allow read: if request.auth != null && resource.data.active == true;
      
      // Only admin can create/update/delete global notifications
      allow create, update, delete: if request.auth != null && 
                                       request.auth.email == 'arerajendhar33@gmail.com';
    }

    // Catch-all: deny access to any unspecified paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
