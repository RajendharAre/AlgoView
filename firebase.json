{
  "firestore": {
    "database": "(default)",
    "location": "asia-south1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "algorithm-visualizer-b963c",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/cf/sendVerificationEmail",
        "function": "sendVerificationEmail",
        "region": "us-central1"
      },
      {
        "source": "/cf/sendEmail",
        "function": "sendEmail",
        "region": "us-central1"
      },
      {
        "source": "/cf/sendWelcomeEmail",
        "function": "sendWelcomeEmail",
        "region": "us-central1"
      },
      {
        "source": "/cf/sendContactEmail",
        "function": "sendContactEmail",
        "region": "us-central1"
      },
      {
        "source": "/cf/sendPasswordResetCode",
        "function": "sendPasswordResetCode",
        "region": "us-central1"
      },
      {
        "source": "/cf/resetUserPassword",
        "function": "resetUserPassword",
        "region": "us-central1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-functions-debug.log"
      ]
    }
  ]
}
